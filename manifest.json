{
  "manifest_version": 3,
  "name": "知乎过滤",
  "version": "1.0.0",
  "description": "过滤知乎页面中的广告和关键词内容",
  "permissions": ["storage", "tabs", "activeTab"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.zhihu.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
